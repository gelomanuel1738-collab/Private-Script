    local function addStat(text)
        local lbl = spyTab:AddLabel(text)
        table.insert(spyStatLabels, lbl)
        return lbl
    end
    local function getStatObj(name, folder)
        local src = folder and plr:FindFirstChild(folder) or plr
        return src and src:FindFirstChild(name)
    end
    pcall(function()
        addStat("👤 "..plr.DisplayName.." (@"..plr.Name..")")
        addStat("📱 Device: "..tostring(plr:FindFirstChild("Device") and plr.Device.Value or "Unknown"))
        addStat("👑 Premium: "..tostring(plr:FindFirstChild("IsPremium") and plr.IsPremium.Value or false))
        addStat("━━━━━━━━ STATS ━━━━━━━━")
        for _, s in ipairs({
            {name="Strong",            icon="💪", folder="leaderstats"},
            {name="Endurance",         icon="🛡️", folder=nil},
            {name="Mobility",          icon="👟", folder=nil},
            {name="Rebirths",          icon="♻️", folder="leaderstats"},
            {name="Kills",             icon="💀", folder="leaderstats"},
            {name="Coins",             icon="🪙", folder=nil},
            {name="Spins",             icon="🎰", folder=nil},
            {name="MuscleEmperorReps", icon="🏋️", folder=nil},
        }) do
            local statObj = getStatObj(s.name, s.folder)
            if statObj then
                local lbl = addStat(s.icon.." "..s.name..": "..formatNumber(statObj.Value))
                local conn = statObj.Changed:Connect(function(v)
                    lbl.Text = s.icon.." "..s.name..": "..formatNumber(v)
                end)
                table.insert(spyConnections, conn)
            end
        end
        local petsFolder = plr:FindFirstChild("PetsFolder")
        if petsFolder then
            local petCount = {}
            for _, pet in ipairs(petsFolder:GetChildren()) do
                petCount[pet.Name] = (petCount[pet.Name] or 0) + 1
            end
            local total = 0
            for _, c in pairs(petCount) do total = total + c end
            if total > 0 then
                addStat("━━━━━━━━ PETS ("..total..") ━━━━━━━━")
                for name, count in pairs(petCount) do
                    addStat("🐾 "..name..(count > 1 and " x"..count or ""))
                end
            end
        end
    end)
end
